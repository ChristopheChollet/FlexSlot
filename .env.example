# GridPulse API (Railway ou local uvicorn :8000)
GRIDPULSE_API_URL=http://localhost:8000

# Démos écosystème (landing)
NEXT_PUBLIC_GRIDPULSE_DEMO_URL=https://grid-pulse-steel.vercel.app
NEXT_PUBLIC_GREENOPS_DEMO_URL=https://green-ops-five.vercel.app

# GreenOps — intégration service-to-service
GREENOPS_API_URL=http://localhost:3000
GREENOPS_SERVICE_KEY=dev-integration-secret
# Org cible démo (profiles.org_id du compte GreenOps connecté)
GREENOPS_DEMO_ORG_ID=

# Supabase (même projet que GreenOps — historique V2)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# V2.1 — alertes recommandation (webhook Slack/Discord/generic)
FLEXSLOT_ALERT_WEBHOOK_URL=
FLEXSLOT_CARBON_ALERT_THRESHOLD_GCO2=200
FLEXSLOT_ALERT_ACTIONS=defer
# Cron proactif (Vercel Cron → GET /api/cron/check-alerts)
CRON_SECRET=

# NEXT_PUBLIC_REPO_URL=https://github.com/ChristopheChollet/FlexSlot

# Sentry (production — erreurs client + serveur)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
